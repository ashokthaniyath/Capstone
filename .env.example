# BlockERP Environment Configuration
# Copy this file to .env and fill in your values

# ============ Private Key ============
# WARNING: Never commit your actual private key!
# Export from MetaMask: Account Details -> Export Private Key
PRIVATE_KEY=your_wallet_private_key_here

# ============ RPC URLs ============
# Get free RPC URLs from:
# - Alchemy: https://www.alchemy.com/
# - Infura: https://infura.io/
# - QuickNode: https://www.quicknode.com/

# Ethereum Sepolia Testnet
SEPOLIA_RPC_URL=https://eth-sepolia.g.alchemy.com/v2/your-api-key

# Ethereum Goerli Testnet (deprecated, use Sepolia)
GOERLI_RPC_URL=https://eth-goerli.g.alchemy.com/v2/your-api-key

# Polygon Mumbai Testnet
MUMBAI_RPC_URL=https://polygon-mumbai.g.alchemy.com/v2/your-api-key

# Ethereum Mainnet (use with caution!)
ETHEREUM_RPC_URL=https://eth-mainnet.g.alchemy.com/v2/your-api-key

# Polygon Mainnet
POLYGON_RPC_URL=https://polygon-mainnet.g.alchemy.com/v2/your-api-key

# ============ Block Explorer API Keys ============
# For contract verification
# Etherscan: https://etherscan.io/myapikey
# Polygonscan: https://polygonscan.com/myapikey
ETHERSCAN_API_KEY=your_etherscan_api_key
POLYGONSCAN_API_KEY=your_polygonscan_api_key

# ============ Gas Reporting ============
# Enable gas reporting in tests
REPORT_GAS=false
# CoinMarketCap API for USD gas costs: https://coinmarketcap.com/api/
COINMARKETCAP_API_KEY=your_coinmarketcap_api_key
